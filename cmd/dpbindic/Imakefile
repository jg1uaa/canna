#include "../../Canna.conf"

      CANNAROOT = ../..
       PROGRAMS = dpbindic
           SRCS = dpbindic.cpp
        DEFINES = -I$(CANNAROOT)/include $(SCRIPTS_DEFINES)

AllTarget($(PROGRAMS))

CppScriptTarget(dpbindic,dpbindic.cpp,$(DEFINES),/**/)
InstallNamedProg(dpbindic,dpbindic,$(cannaBinDir))
InstallManPage(dpbindic,$(cannaManDir))

clean::
	$(RM) $(PROGRAMS)

depend::
