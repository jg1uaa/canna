#include "../../Canna.conf"

      CANNAROOT = ../..
       PROGRAMS = mkromdic
           SRCS = mkromdic.cpp

        DEFINES = -I$(CANNAROOT)/include $(SCRIPTS_DEFINES) -DCPP='$(CPP)'

AllTarget($(PROGRAMS))

CppScriptTarget(mkromdic,mkromdic.cpp,$(DEFINES),/**/)
InstallNamedProg(mkromdic,mkromdic,$(cannaBinDir))
InstallManPage(mkromdic,$(cannaManDir))

clean::
	$(RM) $(PROGRAMS)

depend::
